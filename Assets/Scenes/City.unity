  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1464159d649c5a24db70c6b72d4d3d19, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialScript
  textComponent: {fileID: 609403367}
  lines:
  - Welcome, Handler!
  - Now that you've completed the workplace ethics training module, you're ready
    to join the ranks of MetaMechanica! Consider this the beginning of your trial
    week!
  - As a Handler of the Diplomacy Ward, it is your duty to buy mechs and mech accessories,
    then send them off to where they're needed around the city.
  - As a reminder, hangar space is at a premium, so be sure to make wise choices
    with our money going forward. By helping your fellow citizens and meeting your
    daily quota, you too may help society improve!
  textSpeed: 0.02
